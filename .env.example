# Copy this file to ".env" and fill in the values below.

# Live flight/hotel prices — get a free key at https://serpapi.com/users/sign_up (250 searches/month free).
SERPAPI_KEY=your_serpapi_key_here

PORT=3000

# Accounts + saved itineraries — from your Supabase project's Settings > API page.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
